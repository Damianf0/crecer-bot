# Variables consumidas por docker-compose.yml.
# Copiar este archivo a `.env` (en la raiz, junto a docker-compose.yml) y completar
# los valores con creds propias. NO commitear el .env real.

# MySQL — credenciales del contenedor mysql
DB_DATABASE=clinica
DB_USERNAME=crecer
DB_PASSWORD=cambiar_por_pass_segura
DB_ROOT_PASSWORD=cambiar_por_root_pass_distinta
